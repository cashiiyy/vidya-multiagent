# ============================================================
# Vidya AI – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Google Gemini ────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── MCP Server ───────────────────────────────────────────────
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8000
MCP_SERVER_URL=http://localhost:8000

# ── Application ──────────────────────────────────────────────
APP_NAME=Vidya AI
APP_ENV=development          # development | production
LOG_LEVEL=INFO

# ── Security ─────────────────────────────────────────────────
# Max characters allowed in a single user message
MAX_INPUT_LENGTH=2000
# Enable prompt-injection detection (true/false)
ENABLE_SECURITY_FILTER=true

# ── Google Custom Search API (CSE) ───────────────────────────
# Enables real web search results in search_web and google_custom_search tools.
# Without these, tools fall back gracefully to Gemini knowledge.
#
# Step 1: Enable "Custom Search API" at https://console.cloud.google.com/apis/library
# Step 2: Create an API key at https://console.cloud.google.com/apis/credentials
# Step 3: Create a Custom Search Engine at https://programmablesearch.google.com/
#         → Set "Search the entire web" ON for general results
#         → Copy the "Search engine ID" (cx value)
#
GOOGLE_CSE_API_KEY=your_google_api_key_here
GOOGLE_CSE_ID=your_custom_search_engine_id_here

# ── Data Paths (optional overrides) ──────────────────────────
# DATA_DIR=./data
